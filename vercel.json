{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "fastapi",
  "installCommand": "uv pip install --python .vercel/python/.venv/bin/python -r requirements.txt && cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build && rm -rf ../public && mkdir -p ../public && cp -R dist/. ../public/",
  "cleanUrls": true,
  "redirects": [
    { "source": "/privacy", "destination": "/privacy.html", "permanent": false },
    { "source": "/support", "destination": "/support.html", "permanent": false }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api(?:/|$)|assets/|privacy\\.html$|support\\.html$|icons/|manifest\\.webmanifest$|favicon\\.ico$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
