# === App / auth ===
APP_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
DATABASE_URL=sqlite:///./app.db

# Product UI path on aibusinessagent.xyz is /agents (not a subdomain).
# Stripe success/cancel URLs are built from FRONTEND_URL.
# Never set these to empty string on Vercel (blank overrides defaults).
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://www.aibusinessagent.xyz/agents
# API_PUBLIC_URL=https://www.aibusinessagent.xyz/api
# CORS_ORIGINS=https://aibusinessagent.xyz,https://www.aibusinessagent.xyz
#
# === Google OAuth (Gmail / Sheets / Calendar 1-click) ===
# Web application client in Google Cloud Console.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# Must match Console → Authorized redirect URIs EXACTLY (Error 400 redirect_uri_mismatch):
# OAUTH_REDIRECT_URI=https://www.aibusinessagent.xyz/api/integrations/oauth/callback

# Cron / automation secret for POST /ops/autonomy/tick-all (and similar jobs).
# Send header X-Cron-Secret: <value> or Authorization: Bearer <value>.
# Required in production for non-admin schedulers (e.g. Vercel Cron).
CRON_SECRET=

# Optional: Redis for distributed rate limits (Upstash, Redis Cloud, etc.)
# REDIS_URL=rediss://default:PASSWORD@HOST:6379
# UPSTASH_REDIS_URL=rediss://default:PASSWORD@HOST:6379
REDIS_URL=

# === Outbound email (auth codes, agent mail, notify-human) ===
# Option A — Resend API
# RESEND_API_KEY=re_…
# RESEND_FROM=AI Assistant <noreply@yourdomain.com>
# Option B — Classic SMTP (Namecheap Private Email example)
# SMTP_HOST=mail.privateemail.com
# SMTP_PORT=587
# SMTP_USER=you@yourdomain.com
# SMTP_PASSWORD=your-mailbox-password
# SMTP_FROM=you@yourdomain.com
# SMTP_TLS=1
# Workspace users can also set SMTP under Settings → API keys (BYOK).

# === RunPod Ollama fleet (primary LLM for customers) ===
# Full steps: RUNPOD_CONNECT.md

# Ollama HTTP URL from RunPod proxy (port 11434) — required for production chat
RUNPOD_OLLAMA_URL=https://YOUR_POD_ID-11434.proxy.runpod.net

# Open WebUI for admin embed only (port 8080)
RUNPOD_WEBUI_URL=https://YOUR_POD_ID-8080.proxy.runpod.net

# Optional: if you put auth in front of Ollama
# RUNPOD_API_KEY=

# Neutral client name → Ollama tag (defaults for 24GB 4090)
RUNPOD_MODEL_FAST=qwen2.5:7b
RUNPOD_MODEL_QUALITY=qwen2.5:14b
RUNPOD_MODEL_REASONING=deepseek-r1:8b
RUNPOD_MODEL_LARGE=qwen2.5:14b
RUNPOD_MODEL_SMALL=qwen2.5:3b
RUNPOD_MODEL_MEDIUM=qwen2.5:7b

# Local laptop Ollama only (ignored on Vercel if localhost)
# OLLAMA_URL=http://127.0.0.1:11434

# === xAI / Grok ===
# Production default: XAI_USE_JWT_ONLY=false → prefer XAI_API_KEY (multi-tenant safe).
# Development default: XAI_USE_JWT_ONLY=true → Super/CLI JWT for local work.
XAI_USE_JWT_ONLY=true
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1
# Optional Super/CLI JWT if not using ~/.grok/auth.json:
# GROK_SESSION_TOKEN=
# GROK_JWT=

# === AgentBay marketplace bridge ===
# Public SPA path: https://aibusinessagent.xyz/bay
AGENTBAY_PUBLIC_URL=https://aibusinessagent.xyz/bay
# Bridge target (local AgentBay API or production /bay origin)
AGENTBAY_URL=http://127.0.0.1:8000
# Shared secret with AgentBay BRIDGE_SECRET — use a strong value in production
AGENTBAY_BRIDGE_SECRET=dev-bridge-secret-change-me
# When true, newly created agents are auto-published to AgentBay
AGENTBAY_AUTO_PUBLISH=0
AGENTBAY_DEFAULT_PRICE=29

# === Stripe (optional) ===
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_BUSINESS=

# === Crypto receive addresses (optional; never put private keys here) ===
# CRYPTO_ETH_ADDRESS=
# CRYPTO_SOL_ADDRESS=
# CRYPTO_XRP_ADDRESS=
# CRYPTO_BTC_ADDRESS=
