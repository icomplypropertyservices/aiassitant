# development | production  (production refuses weak JWT_SECRET)
APP_ENV=development

# REQUIRED in production — at least 32 random characters
JWT_SECRET=generate-a-long-random-string-at-least-32-chars

# Encrypts subscriber API keys at rest (Fernet). Optional: derived from JWT_SECRET if empty.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

FRONTEND_URL=http://localhost:5173
# Comma-separated; use your real app origin in production (not *)
CORS_ORIGINS=*

# SQLite (default) or Postgres:
# DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ai_assistant
DATABASE_URL=sqlite:///./app.db

MIN_CREDITS=0.001

# ─── LLM ───────────────────────────────────────────────
# Anthropic — real Claude for "Premium Claude" models
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# xAI — Grok for "Premium xAI Grok" models
# Get key: https://console.x.ai/
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL_FAST=grok-3-mini
XAI_MODEL_QUALITY=grok-3

# Ollama on your VPS (vps-fast / vps-quality / Qwen tiers)
# Install: https://ollama.com
# ollama pull qwen2.5:7b && ollama pull qwen2.5-coder:32b && ollama pull qwen2.5:72b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_FAST=llama3.2
OLLAMA_MODEL_QUALITY=llama3.1:8b
OLLAMA_MODEL_QWEN_FAST=qwen2.5:7b
OLLAMA_MODEL_QWEN_7B=qwen2.5:7b
OLLAMA_MODEL_QWEN_14B=qwen2.5:14b
OLLAMA_MODEL_QWEN_32B=qwen2.5:32b
OLLAMA_MODEL_QWEN_CODER=qwen2.5-coder:32b
OLLAMA_MODEL_QWEN_CODER_7B=qwen2.5-coder:7b
OLLAMA_MODEL_QWEN_CODER_14B=qwen2.5-coder:14b
OLLAMA_MODEL_QWEN_CODER_32B=qwen2.5-coder:32b
OLLAMA_MODEL_QWEN_LARGE=qwen2.5:72b
OLLAMA_MODEL_QWEN_72B=qwen2.5:72b
XAI_MODEL_GROK2=grok-2
XAI_MODEL_GROK3=grok-3
XAI_MODEL_GROK4=grok-4

# ─── Stripe billing ────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook endpoint: https://YOUR_API/billing/webhook
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Products (subscription)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# ─── Email (Resend) ────────────────────────────────────
# https://resend.com/api-keys  — verify your domain first
RESEND_API_KEY=
RESEND_FROM=assistant@yourdomain.com

# ─── SMS + Voice (Twilio) ──────────────────────────────
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
