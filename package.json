{
  "name": "ai-business-assistant-monorepo",
  "private": true,
  "version": "1.4.0",
  "description": "Vercel builds the frontend SPA; FastAPI backend is hosted separately.",
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend install && npm --prefix frontend run build",
    "vercel-build": "sh scripts/vercel-build.sh",
    "preview": "npm --prefix frontend run preview",
    "build:ios": "npm --prefix frontend run build:ios",
    "build:android": "npm --prefix frontend run build:android",
    "build:mobile": "npm --prefix frontend run build:mobile",
    "build:mobile:sandbox": "npm --prefix frontend run build:mobile:sandbox",
    "ios": "npm --prefix frontend run ios",
    "android": "npm --prefix frontend run android",
    "ios:sandbox": "npm --prefix frontend run ios:sandbox",
    "android:sandbox": "npm --prefix frontend run android:sandbox"
  },
  "engines": {
    "node": ">=18"
  }
}
