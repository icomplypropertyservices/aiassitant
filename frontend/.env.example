# Public API base URL (no trailing slash).
#
# Local dev (API on :8000):
VITE_API_URL=http://localhost:8000
#
# Full-stack on Vercel (same origin — leave empty or omit so requests hit /auth, /agents, …):
# VITE_API_URL=
#
# Split deploy (SPA on Vercel, API elsewhere):
# VITE_API_URL=https://api.yourdomain.com
