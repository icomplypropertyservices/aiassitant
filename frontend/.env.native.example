# Copy patterns:
#   .env.native          → store / production native (vite --mode native)
#   .env.native.sandbox  → TestFlight / internal testing (vite --mode native.sandbox)
#
# Sandbox and store currently share the same Vercel API. Card payments use
# Stripe test keys on the server until you switch to sk_live_…

VITE_NATIVE=1
VITE_PROD_API_URL=https://aiassitant-nu.vercel.app/api
# VITE_SANDBOX=1
