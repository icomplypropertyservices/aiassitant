{
  "appId": "com.icomply.aibusinessassistant",
  "appName": "AI Business Assistant",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "allowNavigation": [
      "aiassitant-nu.vercel.app",
      "*.vercel.app",
      "checkout.stripe.com",
      "*.stripe.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#0b1f3a",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0b1f3a"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "iconColor": "#1668dc"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "preferredContentMode": "mobile",
    "scheme": "AI Business Assistant",
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0b1f3a",
    "webContentsDebuggingEnabled": false
  }
}
